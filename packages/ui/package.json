{
  "name": "@md-editor/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "tsc -p tsconfig.build.json",
    "build:css": "tailwindcss -c tailwind.config.ts -i src/styles/tokens.css -o dist/index.css --minify",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "echo \"lint skipped\"",
    "dev": "npm run storybook",
    "storybook": "npm run build:css && storybook dev -p 6006 -c .storybook --ci --no-open --disable-telemetry --no-version-updates"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/builder-vite": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/typography": "^0.5.17",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.4",
    "tailwindcss": "^3.4.16",
    "typescript": "^6.0.2",
    "vite": "^6.0.3"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.0",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "lucide-react": "^1.7.0",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "tiptap-markdown": "^0.9.0"
  }
}